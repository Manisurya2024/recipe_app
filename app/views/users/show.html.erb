<h2><%= @user.name %>'s Profile</h2>

<p>
  <strong>Name:</strong> <%= @user.name %>
</p>

<p>
  <strong>Email:</strong> <%= @user.email %>
</p>

<hr>

<h3>Your Recipes</h3>

<% if @user.recipes.any? %>
  <% @user.recipes.each do |recipe| %>

    <div style="border:1px solid #ccc; padding:15px; margin-bottom:15px; border-radius:8px;">

      <h4>
        <%= link_to recipe.title, recipe_path(recipe) %>
      </h4>

      <p>
        <strong>Description:</strong> <%= recipe.description %>
      </p>

      <p>
        <strong>Category:</strong>
        <span style="background:#007bff; color:white; padding:3px 8px; border-radius:5px;">
          <%= recipe.category.name %>
        </span>
      </p>

      <%= link_to "View", recipe_path(recipe), class: "btn btn-primary" %>

      <% if recipe.user == current_user %>
        <%= link_to "Edit", edit_recipe_path(recipe), class: "btn btn-warning" %>

        <%= link_to "Delete", recipe_path(recipe),
              method: :delete,
              data: { confirm: "Are you sure?" },
              class: "btn btn-danger" %>
      <% end %>

    </div>

  <% end %>
<% else %>
  <p>No recipes yet.</p>
<% end %>