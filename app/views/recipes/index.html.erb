<h1>All Recipes</h1>

<% @recipes.each do |recipe| %>
  <div>
    <h3><%= link_to recipe.title, recipe_path(recipe) %></h3>
    <p><%= recipe.description %></p>
    <p><strong>Category:</strong> <%= recipe.category.name %></p>
    <p><strong>Created by:</strong> <%= recipe.user.name %></p>
    <hr>
  </div>
<% end %>
