<h1 class="mb-4">Recipes</h1>

<div class="row">
  <% @recipes.each do |recipe| %>
    <div class="col-md-4">
      <div class="card mb-4">
        <div class="card-body">
          <h5 class="card-title"><%= recipe.title %></h5>
          <p class="card-text"><%= truncate(recipe.description, length: 100) %></p>
          <%= link_to "View", recipe_path(recipe), class: "btn btn-primary" %>
        </div>
      </div>
    </div>
  <% end %>
</div>